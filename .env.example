# Required for headless first-time login (no saved session yet).
# Copy to .env and fill in your account credentials.
AUTH_EMAIL=user@example.com

# IMAP app password for the mailbox that receives Clerk verification codes.
# Gmail: create an app password at https://myaccount.google.com/apppasswords
# (requires 2FA enabled on the Google account).
# Gmail app passwords contain spaces — keep the value quoted.
AUTH_PASSWORD="your-imap-app-password"

# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993

# Directory where review.py clones submissions via Quick Setup.
# SUBMISSIONS_DIR=./submissions

# After --review, remove the cloned repo and any Docker images/containers
# created by Quick Setup (default: on). Set to 0 to keep artifacts locally.
# CLEANUP_AFTER_REVIEW=1

# Background / overnight orchestrator settings (optional).
# WATCH_INTERVAL_SEC=300
# PROCESS_NICE=10
# LOG_FILE=./logs/orchestrator.log
# SHIPD_FRESH=1            Clear saved batch resume state on next ./run.sh
# Resume state: logs/watch-batch.json (created automatically during multi-review runs)

# Review agent (orchestrator --review / review_agent.py)
# ANTHROPIC_API_KEY=sk-ant-...
# REVIEW_MODEL defaults to claude-opus-4-8 in review/config.py if omitted.
REVIEW_MODEL=claude-opus-4-8
# Faster model for explore phase; finalize keeps REVIEW_MODEL (Opus).
REVIEW_EXPLORE_MODEL=claude-sonnet-4-6
REVIEW_PHASE0=full
# Per test.sh invocation timeout in seconds (base/new, with/without solution).
REVIEW_PHASE0_TEST_TIMEOUT=600
# Docker image build timeout for Phase 0 (seconds).
REVIEW_PHASE0_DOCKER_BUILD_TIMEOUT=600
REVIEW_MAX_TOOL_STEPS=15
# After the explore pass, re-prompt the agent to gather evidence for any rubric
# phase it skipped (bounded + only fires when a required phase has no evidence).
# Set to 0 to disable and rely on guardrails only.
# REVIEW_COVERAGE_RECHECK=1
# Extra tool steps allowed for that recheck pass (kept small for cost).
# REVIEW_COVERAGE_RECHECK_MAX_STEPS=6
REVIEW_RUBRIC_MAX_CHARS=16000
# Token / context budgets (lower = cheaper; may reduce review depth).
# REVIEW_TOOL_READ_MAX_CHARS=12000
# REVIEW_PHASE0_LOG_MAX_CHARS=8000
# REVIEW_EXPLORE_TRANSCRIPT_MAX_CHARS=8000
# REVIEW_TOOL_OUTPUT_MAX_CHARS=600
# REVIEW_SCRAPE_PANEL_MAX_CHARS=2500
# REVIEW_FINALIZE_PAYLOAD_MAX_CHARS=32000
# REVIEW_EXPLORE_MAX_OUTPUT_TOKENS=4096
# REVIEW_FINALIZE_MAX_OUTPUT_TOKENS=8192
# Keep 0 so phases 1-6 are still reviewed when Phase 0 fails (full feedback).
REVIEW_SKIP_EXPLORE_ON_PHASE0_FAIL=0
REVIEW_DRY_RUN=0
# Effective solution LOC thresholds (substantive added lines in solution.patch).
# Defaults come from review/rubric_defaults.py.
REVIEW_OLYMPUS_MIN_LOC=400
REVIEW_MARS_MIN_LOC=100
REVIEW_MARS_MAX_LOC=600